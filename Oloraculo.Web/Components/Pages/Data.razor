@page "/data"
@rendermode InteractiveServer
@inject CsvImportService Importer
@inject RankingRefreshService Rankings
@inject ApiFootballService Api
@inject AvailabilityNewsService Availability
@inject ExternalDataStatusService ExternalDataStatus
@inject OloraculoDbContext Db
@inject ISnackbar Snackbar

<PageTitle>Datos</PageTitle>

<MudStack Spacing="3">
    <div class="page-head">
        <MudText Typo="Typo.h3">Datos</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">Estado de importación CSV y actualización opcional desde API-Football.</MudText>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }

    <MudPaper Class="surface-card" Elevation="0">
        <MudStack Row="true" Spacing="1" Class="action-row">
            <BusyButton Text="Reimportar CSV" BusyText="Importando" IsBusy="_busy" Icon="@Icons.Material.Filled.UploadFile" OnClick="ImportAll" />
            <BusyButton Text="Actualizar rankings" BusyText="Actualizando" IsBusy="_rankingsBusy" Variant="Variant.Outlined" Color="Color.Secondary" Icon="@Icons.Material.Filled.Sync" OnClick="RefreshRankings" />
            <BusyButton Text="Actualizar partidos API-Football" BusyText="Actualizando" IsBusy="_apiBusy" Variant="Variant.Outlined" Color="Color.Secondary" Icon="@Icons.Material.Filled.CloudSync" OnClick="RefreshApi" />
            <BusyButton Text="Actualizar disponibilidad" BusyText="Analizando" IsBusy="_availabilityBusy" Variant="Variant.Outlined" Color="Color.Secondary" Icon="@Icons.Material.Filled.FactCheck" OnClick="RefreshAvailability" />
        </MudStack>
        @if (_busy || _rankingsBusy || _apiBusy || _availabilityBusy)
        {
            <MudProgressLinear Class="inline-progress" Color="Color.Primary" Indeterminate="true" />
        }
        @if (_report is not null)
        {
            <MudAlert Class="mt-2" Severity="Severity.Success" Variant="Variant.Outlined">@_report.Teams equipos, @_report.Groups grupos, @_report.Fixtures partidos, @_report.Results resultados, @_report.Ratings ratings.</MudAlert>
        }
        @if (_rankingsReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_rankingsReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">
                @string.Join(" ", _rankingsReport.Notes)
                @if (_rankingsReport.AnyFileUpdated)
                {
                    <span> Archivos actualizados: @string.Join(", ", _rankingsReport.UpdatedFiles). Ratings importados: @_ratings.</span>
                }
            </MudAlert>
            @foreach (var error in _rankingsReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@error</MudAlert>
            }
        }
        @if (_apiReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_apiReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">Impactos API enriquecidos: @_apiReport.ImpactMatchedPlayers. Fallback por posición: @_apiReport.ImpactFallbackPlayers. @string.Join(" ", _apiReport.Notes)</MudAlert>
            @foreach (var error in _apiReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">Error de proveedor/acceso: @error</MudAlert>
            }
        }
        @if (_availabilityReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_availabilityReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">
                Fuentes leídas: @_availabilityReport.SourcesFetched. Fuentes omitidas: @_availabilityReport.SourcesSkipped. Reclamos guardados: @_availabilityReport.ClaimsSaved. Confirmados out: @_availabilityReport.ConfirmedOutClaims. Dudas: @_availabilityReport.DoubtfulClaims. Disponibles: @_availabilityReport.AvailableClaims. Reclamos que afectan predicciones: @_availabilityReport.ClaimsAffectingPredictions. Roles matcheados: @_availabilityReport.RoleMatchedClaims. Roles desconocidos: @_availabilityReport.RoleUnknownClaims. Impactos enriquecidos: @_availabilityReport.ImpactMatchedClaims. Fallback por posición: @_availabilityReport.ImpactFallbackClaims. Contextos actualizados: @_availabilityReport.ContextRowsUpdated. @string.Join(" ", _availabilityReport.Notes)
            </MudAlert>
            @foreach (var error in _availabilityReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@error</MudAlert>
            }
        }
        @if (_roleReport is not null)
        {
            <MudAlert Class="mt-2" Severity="@(_roleReport.Errors.Count > 0 ? Severity.Warning : Severity.Info)" Variant="Variant.Outlined">
                Enriquecimiento de roles: @_roleReport.RoleMatchedClaims matcheados, @_roleReport.RoleUnknownClaims desconocidos. Impactos enriquecidos: @_roleReport.ImpactMatchedClaims. Fallback por posición: @_roleReport.ImpactFallbackClaims. @string.Join(" ", _roleReport.Notes)
            </MudAlert>
            @foreach (var error in _roleReport.Errors)
            {
                <MudAlert Class="mt-2" Severity="Severity.Warning" Variant="Variant.Outlined">@error</MudAlert>
            }
        }
    </MudPaper>

    <MudPaper Class="surface-card external-status" Elevation="0">
        <MudStack Spacing="2">
            <div class="external-status-head">
                <div>
                    <MudText Typo="Typo.h6">Estado de datos externos</MudText>
                    <MudText Typo="Typo.body2" Class="explain">Muestra configuración, filas persistidas y señales que hoy pueden enriquecer predicciones.</MudText>
                </div>
                <MudChip T="string" Size="Size.Small" Color="@StatusColor" Variant="Variant.Outlined">@StatusLabel</MudChip>
            </div>

            @if (_externalStatus is null)
            {
                <MudSkeleton Height="34px" Class="skeleton-row" />
            }
            else
            {
                <MudAlert Severity="@StatusSeverity" Variant="Variant.Outlined">@_externalStatus.Summary</MudAlert>

                <div class="external-status-grid" aria-label="Resumen de datos externos">
                    <div class="external-status-item"><MudText Typo="Typo.caption">API-Football</MudText><MudText Typo="Typo.body2">@ConfiguredText(_externalStatus.ApiFootballConfigured)</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">OpenRouter</MudText><MudText Typo="Typo.body2">@ConfiguredText(_externalStatus.OpenRouterConfigured)</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">ApiMappings</MudText><MudText Typo="Typo.body2">@_externalStatus.ApiMappings</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">FixtureContexts</MudText><MudText Typo="Typo.body2">@_externalStatus.FixtureContexts</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">AvailabilitySources</MudText><MudText Typo="Typo.body2">@_externalStatus.AvailabilitySources</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">AvailabilityClaims</MudText><MudText Typo="Typo.body2">@_externalStatus.AvailabilityClaims</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">Con noticias</MudText><MudText Typo="Typo.body2">@_externalStatus.ContextsWithAvailabilityNews</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">Con alineaciones</MudText><MudText Typo="Typo.body2">@_externalStatus.ContextsWithLineups</MudText></div>
                    <div class="external-status-item"><MudText Typo="Typo.caption">Con cuotas</MudText><MudText Typo="Typo.body2">@_externalStatus.ContextsWithOdds</MudText></div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_externalStatus.AccessValidationNote))
                {
                    <MudText Typo="Typo.body2" Class="explain">@_externalStatus.AccessValidationNote</MudText>
                }

                @foreach (var error in _externalStatus.LatestProviderErrors)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Error de proveedor/acceso del último refresh: @error</MudAlert>
                }
            }
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="2">
        <MudItem xs="12" md="4"><MudPaper Class="stat-card" Elevation="0"><MudText Typo="Typo.h4">@_teams</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Equipos</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="4"><MudPaper Class="stat-card" Elevation="0"><MudText Typo="Typo.h4">@_fixtures</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Partidos</MudText></MudPaper></MudItem>
        <MudItem xs="12" md="4"><MudPaper Class="stat-card" Elevation="0"><MudText Typo="Typo.h4">@_ratings</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Ratings</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="surface-card" Elevation="0">
        <MudText Typo="Typo.h6">Ratings</MudText>
        @if (!_loaded)
        {
            <MudSkeleton Height="34px" Class="skeleton-row" />
            <MudSkeleton Height="34px" Class="skeleton-row" />
            <MudSkeleton Height="34px" Class="skeleton-row" />
        }
        else
        {
            <MudTable Items="_ratingRows" Dense="true" Hover="true" Elevation="0" Class="dense-table">
                <HeaderContent>
                    <MudTh>Equipo</MudTh>
                    <MudTh>Tipo</MudTh>
                    <MudTh Class="num">Valor</MudTh>
                    <MudTh>Fuente</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Equipo"><TeamLabel TeamId="@context.TeamId" Name="@Name(context.TeamId)" /></MudTd>
                    <MudTd DataLabel="Tipo">@context.Type</MudTd>
                    <MudTd DataLabel="Valor" Class="num">@context.Value.ToString("0")</MudTd>
                    <MudTd DataLabel="Fuente">@context.Source</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudStack>

@code {
    private bool _busy;
    private bool _apiBusy;
    private bool _rankingsBusy;
    private bool _availabilityBusy;
    private bool _loaded;
    private CsvImportReport? _report;
    private RankingRefreshReport? _rankingsReport;
    private ApiFootballRefreshReport? _apiReport;
    private AvailabilityRefreshReport? _availabilityReport;
    private AvailabilityRefreshReport? _roleReport;
    private int _teams;
    private int _fixtures;
    private int _ratings;
    private ExternalDataStatus? _externalStatus;
    private List<Rating> _ratingRows = [];
    private Dictionary<string, string> _names = [];
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        await Load();
        _loaded = true;
    }

    private async Task ImportAll()
    {
        _busy = true;
        _error = "";
        try
        {
            _report = await Importer.ImportAllAsync();
            await Load();
            Snackbar.Add("Datos CSV importados.", Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo importar el CSV.", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RefreshApi()
    {
        _apiBusy = true;
        _error = "";
        try
        {
            _apiReport = await Api.RefreshFixturesAsync();
            await Load();
            Snackbar.Add(_apiReport.Errors.Count > 0 ? "La actualización de API terminó con advertencias." : "Partidos de API-Football actualizados.", _apiReport.Errors.Count > 0 ? Severity.Warning : Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo actualizar API-Football.", Severity.Error);
        }
        finally
        {
            _apiBusy = false;
        }
    }

    private async Task RefreshRankings()
    {
        _rankingsBusy = true;
        _error = "";
        try
        {
            _rankingsReport = await Rankings.RefreshAsync();
            if (_rankingsReport.AnyFileUpdated)
                _ratings = await Importer.ImportRatingsOnlyAsync();
            await Load();
            Snackbar.Add(_rankingsReport.Errors.Count > 0 ? "La actualización de rankings terminó con advertencias." : "Rankings actualizados.", _rankingsReport.Errors.Count > 0 ? Severity.Warning : Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudieron actualizar los rankings.", Severity.Error);
        }
        finally
        {
            _rankingsBusy = false;
        }
    }

    private async Task RefreshAvailability()
    {
        _availabilityBusy = true;
        _error = "";
        try
        {
            _availabilityReport = await Availability.RefreshAsync();
            _roleReport = await Api.EnrichAvailabilityRolesAsync();
            await Load();
            Snackbar.Add(_availabilityReport.Errors.Count > 0 ? "La actualización de disponibilidad terminó con advertencias." : "Disponibilidad actualizada.", _availabilityReport.Errors.Count > 0 ? Severity.Warning : Severity.Success);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("No se pudo actualizar la disponibilidad.", Severity.Error);
        }
        finally
        {
            _availabilityBusy = false;
        }
    }

    private async Task Load()
    {
        _teams = await Db.Teams.CountAsync();
        _fixtures = await Db.Fixtures.CountAsync();
        _ratings = await Db.Ratings.CountAsync();
        _externalStatus = await ExternalDataStatus.GetAsync(_apiReport);
        _names = await Db.Teams.ToDictionaryAsync(t => t.Id, t => t.Name);
        _ratingRows = await Db.Ratings.OrderByDescending(r => r.Value).Take(40).ToListAsync();
    }

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;

    private string ConfiguredText(bool configured) => configured ? "Configurado" : "No configurado";

    private Severity StatusSeverity => _externalStatus?.Tone switch
    {
        ExternalDataStatusTone.Success => Severity.Success,
        ExternalDataStatusTone.Error => Severity.Error,
        ExternalDataStatusTone.Info => Severity.Info,
        _ => Severity.Warning
    };

    private Color StatusColor => _externalStatus?.Tone switch
    {
        ExternalDataStatusTone.Success => Color.Success,
        ExternalDataStatusTone.Error => Color.Error,
        ExternalDataStatusTone.Info => Color.Info,
        _ => Color.Warning
    };

    private string StatusLabel => _externalStatus?.Tone switch
    {
        ExternalDataStatusTone.Success => "Enriquecido",
        ExternalDataStatusTone.Error => "Degradado",
        ExternalDataStatusTone.Info => "Informativo",
        _ => "Revisar"
    };
}
